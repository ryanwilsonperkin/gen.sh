#!/bin/sh
# gen - Generate shell commands using an LLM
# POSIX-compliant shell script
set -e

VERSION="0.2.0"

# --- Debug helper ---
debug() {
    if [ "${DEBUG:-0}" = "1" ]; then
        printf '[gen:debug] %s\n' "$*" >&2
    fi
}

# --- Config resolution ---
resolve_config() {
    if [ -n "$GEN_CONFIG" ] && [ -f "$GEN_CONFIG" ]; then
        debug "config: using GEN_CONFIG=$GEN_CONFIG"
        printf '%s' "$GEN_CONFIG"
        return
    fi
    config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
    debug "config: searching in config_dir=$config_dir"
    if [ -f "$config_dir/gen/genrc.json" ]; then
        debug "config: found $config_dir/gen/genrc.json"
        printf '%s' "$config_dir/gen/genrc.json"
    elif [ -f "$config_dir/.genrc.json" ]; then
        debug "config: found $config_dir/.genrc.json"
        printf '%s' "$config_dir/.genrc.json"
    elif [ -f "$HOME/.genrc.json" ]; then
        debug "config: found $HOME/.genrc.json"
        printf '%s' "$HOME/.genrc.json"
    else
        debug "config: no config file found"
        printf '' 
    fi
}

# --- JSON helpers ---
json_get() {
    jq -r ".$2 // empty" "$1" 2>/dev/null
}

# --- Load config ---
load_config() {
    CONFIG_FILE="$(resolve_config)"
    if [ -z "$CONFIG_FILE" ]; then
        echo "gen: no config file found. Create ~/.config/gen/genrc.json" >&2
        echo "See: gen --help" >&2
        exit 1
    fi

    GEN_API_KEY="${GEN_API_KEY:-$(json_get "$CONFIG_FILE" api_key)}"

    # If no api_key, try apiKeyHelper command
    if [ -z "$GEN_API_KEY" ]; then
        _helper="$(json_get "$CONFIG_FILE" apiKeyHelper)"
        if [ -n "$_helper" ]; then
            debug "config: running apiKeyHelper: $_helper"
            GEN_API_KEY="$(eval "$_helper" 2>/dev/null)"
            if [ -z "$GEN_API_KEY" ]; then
                echo "gen: apiKeyHelper command returned empty output" >&2
                exit 1
            fi
        fi
    fi
    GEN_MODEL="${GEN_MODEL:-$(json_get "$CONFIG_FILE" model)}"
    GEN_API_URL="${GEN_API_URL:-$(json_get "$CONFIG_FILE" api_url)}"
    GEN_PROVIDER="${GEN_PROVIDER:-$(json_get "$CONFIG_FILE" provider)}"
    # Defaults
    GEN_PROVIDER="${GEN_PROVIDER:-openai}"
    GEN_MODEL="${GEN_MODEL:-gpt-4o-mini}"

    # Auto-detect the invoking shell from the parent process
    if [ -z "$GEN_SHELL" ]; then
        _parent_pid="$$"
        # Get parent PID (the shell that invoked gen)
        if [ -f "/proc/$PPID/comm" ]; then
            # Linux: read directly from procfs
            GEN_SHELL="$(cat "/proc/$PPID/comm" 2>/dev/null)"
        else
            # macOS/BSD/POSIX: use ps to get parent process name
            GEN_SHELL="$(ps -p "$PPID" -o comm= 2>/dev/null | sed 's|.*/||')"
        fi
        # Strip leading dash (login shells show as -zsh, -bash)
        GEN_SHELL="${GEN_SHELL#-}"
        # Fallback to $SHELL env var, then sh
        GEN_SHELL="${GEN_SHELL:-$(basename "${SHELL:-/bin/sh}")}"
        debug "shell: auto-detected '$GEN_SHELL' from parent pid $PPID"
    fi

    case "$GEN_PROVIDER" in
        openai)
            GEN_API_URL="${GEN_API_URL:-https://api.openai.com/v1/chat/completions}"
            # Append /chat/completions if URL ends with /v1
            case "$GEN_API_URL" in
                */v1) GEN_API_URL="${GEN_API_URL}/chat/completions" ;;
            esac
            ;;
        anthropic)
            GEN_API_URL="${GEN_API_URL:-https://api.anthropic.com/v1/messages}"
            # Append /messages if URL ends with /v1
            case "$GEN_API_URL" in
                */v1) GEN_API_URL="${GEN_API_URL}/messages" ;;
            esac
            ;;
        ollama)
            GEN_API_URL="${GEN_API_URL:-http://localhost:11434/api/chat}"
            ;;
    esac

    if [ -z "$GEN_API_KEY" ] && [ "$GEN_PROVIDER" != "ollama" ]; then
        echo "gen: api_key not set in config or GEN_API_KEY env var" >&2
        exit 1
    fi

    debug "config: provider=$GEN_PROVIDER model=$GEN_MODEL api_url=$GEN_API_URL shell=$GEN_SHELL"
    _masked_key=""
    if [ -n "$GEN_API_KEY" ]; then
        _key_tail="$(printf '%s' "$GEN_API_KEY" | tail -c 8)"
        _masked_key="set (${#GEN_API_KEY} chars, ends ...$_key_tail)"
    else
        _masked_key="<empty>"
    fi
    debug "config: api_key=$_masked_key"
}

# --- Build the system prompt ---
system_prompt() {
    cat <<'SYSPROMPT'
You are a command-line generator. The user will describe a task and you must respond with EXACTLY one shell command (or pipeline) that accomplishes it. Rules:
- Output ONLY the command. No explanation, no markdown, no code fences, no commentary.
- Do not wrap the command in quotes unless the command itself requires them.
- The command must be valid for the user's shell.
- If the task is ambiguous, pick the most common interpretation.
- Never refuse. Always output a command.
SYSPROMPT
}

# --- Build the retry/alternate prompt ---
alternate_prompt() {
    cat <<'ALTPROMPT'
The user was not satisfied with the previous command. Generate a DIFFERENT command that accomplishes the same task using an alternative approach. Same rules: output ONLY the command, nothing else.
ALTPROMPT
}

# --- API call ---
call_llm() {
    _prompt="$1"
    _alt="$2"  # non-empty means "try alternate"
    _sys="$(system_prompt)"
    _shell_hint="Target shell: $GEN_SHELL"

    if [ -n "$_alt" ]; then
        _user_content="$_shell_hint

Previous command (try a different approach): $_alt

Task: $_prompt"
    else
        _user_content="$_shell_hint

Task: $_prompt"
    fi

    debug "prompt: $_user_content"

    _curl_err_file=""
    if [ "${DEBUG:-0}" = "1" ]; then
        _curl_err_file="$(mktemp "${TMPDIR:-/tmp}/gen-curl-err.XXXXXX")"
    fi

    case "$GEN_PROVIDER" in
        openai)
            _payload="$(cat <<EOF
{
  "model": "$GEN_MODEL",
  "temperature": 0.2,
  "max_tokens": 512,
  "messages": [
    {"role": "system", "content": $(printf '%s' "$_sys" | _json_encode)},
    {"role": "user", "content": $(printf '%s' "$_user_content" | _json_encode)}
  ]
}
EOF
)"
            debug "request: POST $GEN_API_URL"
            debug "payload: $_payload"
            if [ -n "$_curl_err_file" ]; then
                _response="$(curl -sS -X POST "$GEN_API_URL" \
                    -H "Content-Type: application/json" \
                    -H "Authorization: Bearer $GEN_API_KEY" \
                    -d "$_payload" 2>"$_curl_err_file")"
                _curl_exit=$?
            else
                _response="$(curl -sS -X POST "$GEN_API_URL" \
                    -H "Content-Type: application/json" \
                    -H "Authorization: Bearer $GEN_API_KEY" \
                    -d "$_payload" 2>/dev/null)"
                _curl_exit=$?
            fi
            debug "curl exit code: $_curl_exit"
            if [ -n "$_curl_err_file" ] && [ -s "$_curl_err_file" ]; then
                debug "curl stderr: $(cat "$_curl_err_file")"
            fi
            debug "raw response: $_response"
            _extracted="$(printf '%s' "$_response" | _extract_openai)"
            debug "extracted: $_extracted"
            printf '%s' "$_extracted"
            ;;
        anthropic)
            _payload="$(cat <<EOF
{
  "model": "$GEN_MODEL",
  "max_tokens": 512,
  "system": $(printf '%s' "$_sys" | _json_encode),
  "messages": [
    {"role": "user", "content": $(printf '%s' "$_user_content" | _json_encode)}
  ]
}
EOF
)"
            debug "request: POST $GEN_API_URL"
            debug "payload: $_payload"
            if [ -n "$_curl_err_file" ]; then
                _response="$(curl -sS -X POST "$GEN_API_URL" \
                    -H "Content-Type: application/json" \
                    -H "x-api-key: $GEN_API_KEY" \
                    -H "anthropic-version: 2023-06-01" \
                    -d "$_payload" 2>"$_curl_err_file")"
                _curl_exit=$?
            else
                _response="$(curl -sS -X POST "$GEN_API_URL" \
                    -H "Content-Type: application/json" \
                    -H "x-api-key: $GEN_API_KEY" \
                    -H "anthropic-version: 2023-06-01" \
                    -d "$_payload" 2>/dev/null)"
                _curl_exit=$?
            fi
            debug "curl exit code: $_curl_exit"
            if [ -n "$_curl_err_file" ] && [ -s "$_curl_err_file" ]; then
                debug "curl stderr: $(cat "$_curl_err_file")"
            fi
            debug "raw response: $_response"
            _extracted="$(printf '%s' "$_response" | _extract_anthropic)"
            debug "extracted: $_extracted"
            printf '%s' "$_extracted"
            ;;
        ollama)
            _payload="$(cat <<EOF
{
  "model": "$GEN_MODEL",
  "stream": false,
  "messages": [
    {"role": "system", "content": $(printf '%s' "$_sys" | _json_encode)},
    {"role": "user", "content": $(printf '%s' "$_user_content" | _json_encode)}
  ]
}
EOF
)"
            debug "request: POST $GEN_API_URL"
            debug "payload: $_payload"
            if [ -n "$_curl_err_file" ]; then
                _response="$(curl -sS -X POST "$GEN_API_URL" \
                    -H "Content-Type: application/json" \
                    -d "$_payload" 2>"$_curl_err_file")"
                _curl_exit=$?
            else
                _response="$(curl -sS -X POST "$GEN_API_URL" \
                    -H "Content-Type: application/json" \
                    -d "$_payload" 2>/dev/null)"
                _curl_exit=$?
            fi
            debug "curl exit code: $_curl_exit"
            if [ -n "$_curl_err_file" ] && [ -s "$_curl_err_file" ]; then
                debug "curl stderr: $(cat "$_curl_err_file")"
            fi
            debug "raw response: $_response"
            _extracted="$(printf '%s' "$_response" | _extract_ollama)"
            debug "extracted: $_extracted"
            printf '%s' "$_extracted"
            ;;
        *)
            echo "gen: unsupported provider '$GEN_PROVIDER'" >&2
            exit 1
            ;;
    esac

    # Cleanup temp file
    if [ -n "$_curl_err_file" ]; then
        rm -f "$_curl_err_file"
    fi
}

# --- JSON string encoder ---
_json_encode() {
    jq -Rs .
}

# --- Response extractors ---
# Use ? to suppress jq errors (e.g. indexing a string) so // can fall through.
_extract_openai() {
    jq -r '(.choices[0].message.content)? // (.error.message)? // "gen: API error"'
}

_extract_anthropic() {
    jq -r '(.content[0].text)? // (.error.message)? // "gen: API error"'
}

_extract_ollama() {
    jq -r '(.message.content)? // (.error)? // "gen: API error"'
}

# --- Strip markdown code fences if LLM ignores instructions ---
strip_fences() {
    sed '/^```.*$/d'
}

# --- Usage ---
usage() {
    cat <<'EOF'
gen - Generate shell commands using an LLM

Usage:
    gen <description>          Generate a command and print to stdout
    gen -y <description>       Generate, display, and execute the command
    gen -x "<command>"         Execute a pre-generated command (used after tab completion)
    gen --complete <words>     Tab-completion helper (internal)

Options:
    -y, --yes                  Execute the generated command immediately
    -x, --exec-display         Execute a pre-generated command (tab completion + enter)
    -h, --help                 Show this help
    -v, --version              Show version

Config:
    Reads from (in order):
      $GEN_CONFIG                 (env var override)
      $XDG_CONFIG_HOME/gen/genrc.json
      ~/.config/gen/genrc.json
      ~/.config/.genrc.json
      ~/.genrc.json

    Config format (JSON):
      {
        "provider": "openai",
        "api_key": "sk-...",
        "model": "gpt-4o-mini",
        "api_url": "https://api.openai.com/v1/chat/completions"
      }

    Use apiKeyHelper to fetch the key from a command (e.g. a secret manager):
      {
        "provider": "openai",
        "apiKeyHelper": "op read 'op://Private/OpenAI/api_key'",
        "model": "gpt-4o-mini"
      }

    Supported providers: openai, anthropic, ollama
    The target shell is auto-detected from your current shell.
    Environment overrides: GEN_API_KEY, GEN_MODEL, GEN_API_URL, GEN_PROVIDER, GEN_SHELL

Tab Completion:
    # bash (add to ~/.bashrc):
    eval "$(gen --shell-init bash)"

    # zsh (add to ~/.zshrc):
    eval "$(gen --shell-init zsh)"

    # fish (add to ~/.config/fish/config.fish):
    gen --shell-init fish | source
EOF
}

# --- Shell init scripts ---
shell_init() {
    case "$1" in
        bash)
            cat <<'BASHINIT'
# gen tab completion for bash
# Uses bind -x for READLINE_LINE access. Only intercepts "gen " lines.
# No background jobs (bash prints job notifications inside bind -x that
# can't be suppressed), so we use a static indicator instead.

_gen_tab_handler() {
    [[ "$READLINE_LINE" == gen\ * ]] || return 0
    local prompt="${READLINE_LINE#gen }"
    [[ -z "$prompt" || "$prompt" == -* ]] && return 0

    # Show a static loading indicator at end of line, hide cursor
    printf '\033[s \033[2m…\033[0m\033[?25l' >/dev/tty

    local result
    result="$(command gen --complete -- "$prompt" 2>/dev/null)"

    # Clear indicator and restore cursor
    printf '\033[u\033[K\033[?25h' >/dev/tty

    if [[ -n "$result" ]]; then
        READLINE_LINE="$result"
        READLINE_POINT=${#READLINE_LINE}
    fi
}

bind -x '"\C-i": _gen_tab_handler'
BASHINIT
            ;;
        zsh)
            cat <<'ZSHINIT'
# gen tab completion for zsh
# When the line starts with "gen ", tab replaces the entire line with the
# LLM-generated command. Otherwise falls through to expand-or-complete.

_gen_spinner_start() {
    {
        local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
        local i=0
        printf '\033[?25l' >/dev/tty
        while true; do
            printf '\033[s \033[1m%s\033[0m\033[u' "${frames:$i:1}" >/dev/tty
            sleep 0.1
            (( i = (i + 1) % ${#frames} ))
        done
    } &!
    _gen_spinner_pid=$!
}

_gen_spinner_stop() {
    if [[ -n "${_gen_spinner_pid:-}" ]]; then
        kill "$_gen_spinner_pid" 2>/dev/null
        wait "$_gen_spinner_pid" 2>/dev/null
        _gen_spinner_pid=""
    fi
    printf '\033[K\033[?25h' >/dev/tty
}

_gen_do_complete() {
    local prompt="${BUFFER#gen }"

    # Skip if empty or a flag
    [[ -z "$prompt" || "$prompt" == -* ]] && return 1

    _gen_spinner_start

    local result
    result="$(command gen --complete -- "$prompt" 2>/dev/tty)"

    _gen_spinner_stop

    if [[ -n "$result" ]]; then
        BUFFER="$result"
        CURSOR=${#BUFFER}
        return 0
    fi
    return 1
}

_gen_tab_dispatch() {
    if [[ "$BUFFER" == gen\ * ]]; then
        _gen_do_complete || zle expand-or-complete
    else
        zle expand-or-complete
    fi
}

zle -N _gen_tab_dispatch
bindkey '^I' _gen_tab_dispatch
ZSHINIT
            ;;
        fish)
            cat <<'FISHINIT'
# gen tab completion for fish
# When the line starts with "gen ", tab replaces the entire line with the
# LLM-generated command. Otherwise falls through to normal completion.

function __gen_spinner_start
    begin
        set -l frames ⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏
        printf '\033[?25l' >/dev/tty
        set -l i 1
        while true
            printf '\033[s \033[1m%s\033[0m\033[u' $frames[$i] >/dev/tty
            sleep 0.1
            set i (math "($i % 10) + 1")
        end
    end &
    set -g __gen_spinner_pid (jobs -lp | tail -1)
end

function __gen_spinner_stop
    if set -q __gen_spinner_pid
        kill $__gen_spinner_pid 2>/dev/null
        wait $__gen_spinner_pid 2>/dev/null
        set -e __gen_spinner_pid
    end
    printf '\033[K\033[?25h' >/dev/tty
end

function __gen_do_complete
    set -l buf (commandline -b)
    set -l prompt (string replace -r '^gen\s+' '' -- "$buf")

    test -z "$prompt"; and return 1
    string match -qr '^-' -- "$prompt"; and return 1

    __gen_spinner_start

    set -l result (command gen --complete -- "$prompt" 2>/dev/tty)

    __gen_spinner_stop

    if test -n "$result"
        commandline -r "$result"
        commandline -f repaint
        return 0
    end

    # Restore original on failure
    commandline -r "gen $prompt"
    commandline -f repaint
    return 1
end

function __gen_tab_handler
    set -l buf (commandline -b)
    if string match -qr '^gen\s' -- "$buf"
        __gen_do_complete; or commandline -f complete
    else
        commandline -f complete
    end
end

bind \t __gen_tab_handler
FISHINIT
            ;;
        *)
            echo "gen: unsupported shell '$1' (use bash, zsh, or fish)" >&2
            exit 1
            ;;
    esac
}

# --- Main ---
main() {
    # Handle meta-flags before loading config
    case "${1:-}" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            echo "gen $VERSION"
            exit 0
            ;;
        --shell-init)
            shell_init "${2:-bash}"
            exit 0
            ;;
    esac

    # Parse flags
    execute_mode=0
    exec_display_mode=0
    complete_mode=0
    alt_prev=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -y|--yes)
                execute_mode=1
                shift
                ;;
            -x|--exec-display)
                exec_display_mode=1
                shift
                ;;
            --complete)
                complete_mode=1
                shift
                ;;
            --alt)
                shift
                alt_prev="$1"
                shift
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "gen: unknown option '$1'" >&2
                echo "Try 'gen --help' for more information." >&2
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done

    prompt="$*"

    debug "mode: execute=$execute_mode exec_display=$exec_display_mode complete=$complete_mode"
    debug "prompt: '$prompt'"
    if [ -n "$alt_prev" ]; then
        debug "alt_prev: '$alt_prev'"
    fi

    # -x mode: execute a pre-generated command (used after tab completion + enter)
    if [ "$exec_display_mode" = 1 ]; then
        if [ -z "$prompt" ]; then
            echo "gen: no command provided" >&2
            exit 1
        fi
        debug "exec-display: '$prompt'"
        printf '%s\n' "$prompt" >&2
        eval "$prompt"
        exit $?
    fi

    if [ -z "$prompt" ]; then
        usage
        exit 1
    fi

    # Complete mode: return the generated command for tab completion
    if [ "$complete_mode" = 1 ]; then
        load_config
        result="$(call_llm "$prompt" "$alt_prev" | strip_fences | tr '\n' ' ' | sed 's/  */ /g; s/^ //; s/ $//')"
        debug "complete result: '$result'"
        printf '%s' "$result"
        exit 0
    fi

    # Normal generation mode
    load_config
    result="$(call_llm "$prompt" "" | strip_fences)"
    debug "final result: '$result'"

    if [ "$execute_mode" = 1 ]; then
        # -y mode: display on stderr, execute
        debug "executing: $result"
        printf '%s\n' "$result" >&2
        eval "$result"
    else
        # Default: just print to stdout
        printf '%s\n' "$result"
    fi
}

main "$@"
